{
  "permissions": {
    "allow": [
      "Bash(npm run dev:*)",
      "Bash(npm run build:*)",
      "Bash(npm run lint:*)",
      "Bash(npm run type-check:*)",
      "Bash(npm install:*)",
      "Bash(npx playwright test:*)",
      "Bash(npx playwright test --ui:*)",
      "Bash(node:*)",
      "Bash(mkdir:*)",
      "Bash(ls:*)",
      "Bash(cat:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"const p=process.env.CLAUDE_TOOL_INPUT_FILE_PATH||''; if(p.includes('backend/routes')||p.includes('backend/store')){console.log('[hook] Backend file changed: '+p);}\"",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
